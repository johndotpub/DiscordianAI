# DiscordianAI environment variables

# Discord bot token
# DISCORD_TOKEN=

# Comma-separated channel names
# ALLOWED_CHANNELS=

# Comma-separated channel IDs
# ALLOWED_CHANNEL_IDS=

# Bot presence and activity
# BOT_PRESENCE=online
# ACTIVITY_TYPE=listening
# ACTIVITY_STATUS=Humans

# OpenAI configuration
# OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1/

# Perplexity configuration
# PERPLEXITY_API_KEY=
# PERPLEXITY_API_URL=https://api.perplexity.ai
# PERPLEXITY_MODEL=sonar-pro

# Default AI model and token limits
# GPT_MODEL=gpt-5-mini
# INPUT_TOKENS=120000
# OUTPUT_TOKENS=8000
# CONTEXT_WINDOW=128000

# System prompt
# SYSTEM_MESSAGE=You are a helpful assistant.

# Rate limiting
# RATE_LIMIT=10
# RATE_LIMIT_PER=60

# Connection pooling
# OPENAI_MAX_CONNECTIONS=50
# OPENAI_MAX_KEEPALIVE=10
# PERPLEXITY_MAX_CONNECTIONS=30
# PERPLEXITY_MAX_KEEPALIVE=5

# Orchestrator settings
# LOOKBACK_MESSAGES_FOR_CONSISTENCY=6
# MAX_HISTORY_PER_USER=50
# USER_LOCK_CLEANUP_INTERVAL=3600
# ENTITY_DETECTION_MIN_WORDS=10

# Logging
# LOG_FILE=bot.log
# LOG_LEVEL=INFO
# DISCORDIANAI_LOG_COLOR=1  # Colors on by default; set 0/false/no to disable
